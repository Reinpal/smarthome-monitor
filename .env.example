# Stiebel Eltron ISG Configuration
ISG_BASE_URL=http://192.168.1.100

# Scrape interval in seconds (default: 300 = 5 minutes)
SCRAPE_INTERVAL_SECONDS=300

# Fronius Solar API Configuration
FRONIUS_ENABLED=true
FRONIUS_BASE_URL=http://192.168.1.200
FRONIUS_POLL_INTERVAL_SECONDS=30

# OpenTelemetry Collector endpoint (inside Docker network)
OTEL_EXPORTER_OTLP_ENDPOINT=http://lgtm:4317

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Grafana admin password (default: admin)
GF_SECURITY_ADMIN_PASSWORD=admin
